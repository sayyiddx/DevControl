<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/DevControl;component/Themes/Colors/Light.xaml"/>
        <ResourceDictionary Source="/DevControl;component/Themes/IconLibrary.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Color x:Key="TransparentColor">#00000000</Color>
    <SolidColorBrush x:Key="NormalBlack" Color="Black"/>
    <SolidColorBrush x:Key="NormalTransparentBrush" Color="#00000000" />

    <SolidColorBrush x:Key="NormalForeground" Color="{DynamicResource NormalForegroundColor}"/>
    <SolidColorBrush x:Key="WindowBackground" Color="{DynamicResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="NormalBorderBrush" Color="{DynamicResource NormalBorderColor}"/>

</ResourceDictionary>