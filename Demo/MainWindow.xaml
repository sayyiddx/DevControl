<DevControl:MetroWindow x:Class="Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:DevControl="clr-namespace:DevControl.Controls.Metro;assembly=DevControl"
        xmlns:local="clr-namespace:Demo"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="700"
        Width="1250"
        MinWidth="650"
        MinHeight="350"
        Background="White"
      SysButtonColor="Blue"
      BorderBrush="MediumVioletRed"
      TitleForeground="Black">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Probando window personalizado"
                       FontSize="24"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>
            <Button Content="Botón de prueba"
                    Width="150"
                    Height="35"/>
        </StackPanel>
    </Grid>
</DevControl:MetroWindow>
